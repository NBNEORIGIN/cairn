# /var/spool/cron/crontabs/root — canonical version
# Owner: deek/deploy/host-config/crontab.canonical
# Sync via: deek/deploy/host-config/sync-to-host.sh
#
# DO NOT EDIT THE LIVE CRONTAB DIRECTLY. Edit this file, commit,
# then run sync-to-host.sh from a Deek dev box. The sync script
# diffs before applying and aborts on suspicious removals.
#
# Schedule grouping:
#   ── Disk hygiene ──        02:00 daily / Monday 02:30 / hourly
#   ── Disk alerts ──         every 15 min
#   ── Cairn / Deek crons ──  existing operational schedule
#   ── Backups ──             03:00 daily (ark + nbne backup.sh)
#   ── Wiki / Etsy / FX ──    existing operational schedule

# ─────────────────────────────────────────────────────────────────────
# Disk hygiene & alerts (Deek host-config 2026-05-15)
# ─────────────────────────────────────────────────────────────────────
0  2 * * *      /opt/nbne/scripts/prune-daily.sh >> /var/log/nbne-prune.log 2>&1
30 2 * * 1      /opt/nbne/scripts/prune-weekly.sh >> /var/log/nbne-prune.log 2>&1
5  * * * *      /opt/nbne/scripts/disk-telemetry.sh >> /var/log/nbne-disk-telemetry.log 2>&1
*/15 * * * *    /opt/nbne/scripts/disk-alert.sh >> /var/log/nbne-disk-alert.log 2>&1

# ─────────────────────────────────────────────────────────────────────
# Cairn / Deek operational crons
# ─────────────────────────────────────────────────────────────────────
0 23 * * 0 curl -sf -X POST http://localhost:8765/api/wiki/compile?scope=all >> /var/log/cairn-wiki-compile.log 2>&1
0 */2 * * * docker exec -w /app -e PYTHONPATH=/app deploy-deek-api-1 python -m scripts.backfill.run --source crm_reflection --max-bulk-llm-calls 50 --commit --run-id crm-reflection-$(date +\%s) --sample-size 0 >> /var/log/cairn-crm-reflection.log 2>&1
