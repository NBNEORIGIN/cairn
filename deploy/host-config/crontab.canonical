# Wiki / FX / Etsy / Amazon
# ─────────────────────────────────────────────────────────────────────
30 */4 * * * cd /opt/nbne/deek && git pull --ff-only origin master >> /var/log/cairn-wiki-sync.log 2>&1 && curl -s -X POST http://localhost:8765/admin/wiki-sync -H "X-API-Key: claw-dev-key-change-in-production" >> /var/log/cairn-wiki-sync.log 2>&1
0 6 * * * curl -sf -X POST http://localhost:8765/api/wiki/compile?scope=modules >> /var/log/cairn-wiki-compile.log 2>&1
0 7 * * * docker exec -w /app -e PYTHONPATH=/app deploy-deek-api-1 python scripts/run_fx_sync.py >> /var/log/deek-fx-sync.log 2>&1
15 7 * * * docker exec -w /app -e PYTHONPATH=/app deploy-deek-api-1 python -c "import asyncio; from core.etsy_intel.sync import sync_all; print(asyncio.run(sync_all()))" >> /var/log/deek-etsy-sync.log 2>&1
0 */6 * * * curl -s -X POST http://localhost:8765/ami/spapi/sync -H "X-API-Key: vtGHpaK5NwkTIezBigwkifanrzoeWVC6D_k3Vr1D9Oc" >> /var/log/deek-ami-sync.log 2>&1

# ─────────────────────────────────────────────────────────────────────
# Manufacture
# ─────────────────────────────────────────────────────────────────────
0 6 * * * cd /opt/nbne/manufacture && docker exec docker-backend-1 python manage.py sync_restock_all >> /var/log/manufacture-restock.log 2>&1

# ─────────────────────────────────────────────────────────────────────
# Backups (run after operational crons quiet down)
# ─────────────────────────────────────────────────────────────────────
0 3 * * * /opt/nbne/scripts/backup.sh >> /var/log/nbne-backup.log 2>&1
30 3 * * * /opt/ark/backup.sh >> /var/log/ark-backup.log 2>&1
0 3 * * 0 tar -czf /opt/nbne/backups/clayport-uploads-$(date +\%Y\%m\%d).tar.gz /opt/nbne/client-sites/clayport/images/uploads/

# ─────────────────────────────────────────────────────────────────────
# Ark backup local retention (added 2026-05-15 — cleans daily snapshots
# older than 14 days; remote snapshots still go to nbne1 180d + Contabo)
# ─────────────────────────────────────────────────────────────────────
0 4 * * * find /backups/ark/daily/*/ -maxdepth 1 -mindepth 1 -type d -mtime +14 -exec rm -rf {} + >> /var/log/ark-local-prune.log 2>&1
