32 7 * * * docker exec -w /app -e PYTHONPATH=/app deploy-deek-api-1 python scripts/send_memory_brief.py --user jo@nbnesigns.com >> /var/log/deek-memory-brief-jo.log 2>&1
34 7 * * * docker exec -w /app -e PYTHONPATH=/app deploy-deek-api-1 python scripts/send_memory_brief.py --user ivan@nbnesigns.com >> /var/log/deek-memory-brief-ivan.log 2>&1
