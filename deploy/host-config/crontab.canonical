*/30 * * * * docker exec -w /app -e PYTHONPATH=/app -e DEEK_EMAIL_TRIAGE_ENABLED=true deploy-deek-api-1 python -m scripts.email_triage.triage_runner --max-emails 5 --window-days 7 --commit >> /var/log/cairn-triage.log 2>&1
