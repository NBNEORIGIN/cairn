0 8 * * * curl -s -X POST http://127.0.0.1:3023/api/cairn/email/scheduled-review -H "x-api-key: $(grep ^CAIRN_API_KEY= /opt/crm/.env | cut -d= -f2)" >> /var/log/crm-email-review.log 2>&1
