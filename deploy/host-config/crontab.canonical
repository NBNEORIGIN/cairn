30 7 * * * docker exec -w /app -e PYTHONPATH=/app deploy-deek-api-1 python scripts/nudge_stalled_projects.py >> /var/log/deek-nudge-stalled.log 2>&1
*/5 * * * * docker exec -w /app -e PYTHONPATH=/app deploy-deek-api-1 python scripts/send_pending_nudges.py >> /var/log/deek-nudge-sender.log 2>&1
